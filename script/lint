#!/usr/bin/env bash
# Run SwiftLint + SwiftFormat (check-only) against the working tree.
#
# Direct SwiftLint binaries crash on Swift 6.3.1 Linux toolchains
# (libFoundation.so SIGILL), so this helper prefers Docker on Linux and
# falls back to the host binaries otherwise.
#
# Mirrors the macOS CI `lint-build-test` job: lint + format-check + build.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

STRICT="${STRICT:-1}"
LINT_ARGS=()
if [[ "$STRICT" == "1" ]]; then
    LINT_ARGS+=(--strict)
fi

run_swiftlint() {
    if [[ "$(uname -s)" == "Linux" ]] && command -v docker >/dev/null 2>&1; then
        docker run --rm -v "$PWD:/work" -w /work \
            ghcr.io/realm/swiftlint:0.63.2 \
            swiftlint "${LINT_ARGS[@]}" "$@"
    elif command -v swiftlint >/dev/null 2>&1; then
        swiftlint "${LINT_ARGS[@]}" "$@"
    else
        echo "swiftlint not found. Install via 'brew install swiftlint' or use Docker." >&2
        return 1
    fi
}

run_swiftformat_check() {
    if [[ "$(uname -s)" == "Linux" ]] && command -v docker >/dev/null 2>&1; then
        docker run --rm -v "$PWD:/work" -w /work \
            ghcr.io/nicklockwood/swiftformat:latest \
            --lint . "$@"
    elif command -v swiftformat >/dev/null 2>&1; then
        swiftformat --lint . "$@"
    else
        echo "swiftformat not found. Install via 'brew install swiftformat' or use Docker." >&2
        return 1
    fi
}

echo "==> SwiftLint"
run_swiftlint
echo
echo "==> SwiftFormat (check-only)"
run_swiftformat_check
echo
echo "All checks passed."
