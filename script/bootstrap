#!/usr/bin/env bash
# Set up a local dev environment. Idempotent.
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

echo "==> Bootstrapping Sprig dev environment"

if ! command -v swift >/dev/null 2>&1; then
    echo "Swift toolchain not found. Install Swift 6.3+ from https://swift.org/download" >&2
    exit 1
fi

if ! command -v git >/dev/null 2>&1; then
    echo "git not found. On macOS: 'xcode-select --install' or 'brew install git'." >&2
    exit 1
fi

# package-benchmark links jemalloc for malloc-tracking metrics on every
# platform that supports it (macOS + Linux; Windows excluded entirely from
# the benchmark target, see Package.swift). Resolved via pkg-config +
# system jemalloc rather than vendored, so we need the dev package on
# macOS too — even though earlier docs claimed it was bundled.
case "$(uname -s)" in
    Linux)
        if ! [[ -e /usr/include/jemalloc/jemalloc.h ]]; then
            echo "libjemalloc-dev not installed."
            echo "  Debian/Ubuntu: sudo apt-get install -y libjemalloc-dev"
            echo "  Fedora:        sudo dnf install -y jemalloc-devel"
            echo "  Arch:          sudo pacman -S jemalloc"
            echo "Without it, 'swift build --target SprigCoreBenchmarks' will fail."
            echo "(Other targets build fine.)"
        fi
        ;;
    Darwin)
        if ! command -v pkg-config >/dev/null 2>&1 \
            || ! pkg-config --exists jemalloc 2>/dev/null; then
            echo "jemalloc not installed (or not pkg-config-discoverable)."
            echo "  Homebrew: brew install jemalloc"
            echo "Without it, 'swift build --target SprigCoreBenchmarks' will fail."
            echo "(Other targets build fine.)"
        fi
        ;;
esac

echo "==> Resolving SwiftPM dependencies"
swift package resolve

echo "==> Building packages (portable graph)"
swift build

echo "==> Done. Run './script/test' to verify your environment."
